# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/habishop
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/habishop
MONGO_URI=mongodb://mondayhabib:mondayhabib@ac-3yt8dar-shard-00-00.ndk0hm4.mongodb.net:27017,ac-3yt8dar-shard-00-01.ndk0hm4.mongodb.net:27017,ac-3yt8dar-shard-00-02.ndk0hm4.mongodb.net:27017/?ssl=true&replicaSet=atlas-pxd9ya-shard-0&authSource=admin&appName=Cluster0

# ── JWT ───────────────────────────────────────────────────────────────
# IMPORTANT: Change both secrets before deploying to production!
JWT_SECRET=habishop_jwt_s3cr3t_change_in_prod_2024
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=habishop_refresh_s3cr3t_change_in_prod_2024
JWT_REFRESH_EXPIRE=30d

# ── CORS ──────────────────────────────────────────────────────────────
# Local dev:   http://localhost:5173
# Production:  https://habishop.vercel.app  (or your frontend URL)
FRONTEND_URL=http://localhost:5173

# ── Cloudinary (optional – cloud image hosting) ───────────────────────
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Paystack (payment gateway) ────────────────────────────────────────
# Get from https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (alternative payment) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email / SMTP (optional – for order confirmations) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=noreply@habishop.com
FROM_NAME=HabiShop
